PROJECT_NAME=JVS
VERSION=0.1.0

# ── 数据库 ────────────────────────────────────────────────────────────────────
# 开发环境（SQLite，默认）
DATABASE_URL=sqlite:///./dev.db
# 生产环境（PostgreSQL，取消注释并填写密码）
# DATABASE_URL=postgresql://jvs:change-me@postgres:5432/jvs

# ── Redis ─────────────────────────────────────────────────────────────────────
# 开发环境
REDIS_URL=redis://localhost:6379/0
# 生产环境（Docker Compose 内部）
# REDIS_URL=redis://redis:6379/0

# ── 安全 ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── CORS ──────────────────────────────────────────────────────────────────────
# 开发环境
CORS_ORIGINS=http://localhost:3001,http://localhost:3002
# 生产方案一（全量 VPS）：填自有域名
# CORS_ORIGINS=https://example.com
# 生产方案二（Vercel + VPS）：填 VPS 域名 + Vercel 域名
# CORS_ORIGINS=https://example.com,https://your-app.vercel.app

# ── 生产部署专用（以下变量仅在 VPS 的 .env 中填写，不提交到 git）────────────

# 域名（build 脚本和 nginx 模板使用）
# DOMAIN=example.com

# 部署方案：plan1（全量 VPS）或 plan2（Vercel + VPS）
# DEPLOY_PLAN=plan1

# PostgreSQL 容器账号（DATABASE_URL 中的 user/password 需与此一致）
# POSTGRES_DB=jvs
# POSTGRES_USER=jvs
# POSTGRES_PASSWORD=change-me

# 方案二专用：Vercel CLI token（在 vercel.com/account/tokens 获取）
# VERCEL_TOKEN=
